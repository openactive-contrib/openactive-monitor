GCP_PROJECT_ID=openactive-monitor
BQ_DATASET_ID=openactive_analytics

# Input tables (written by ingest_feeds / ingest-opportunities)
BQ_FEEDS_TABLE=feeds
BQ_OPPORTUNITIES_TABLE=opportunities
BQ_OPPORTUNITY_INGESTION_TABLE=opportunity_ingestion

# Output tables (created by this job's --init-tables flag)
BQ_FEED_INSIGHTS_TABLE=feed_insights
BQ_INSIGHT_RUN_SUMMARY_TABLE=insight_run_summary
BQ_INSIGHT_CATEGORY_COUNTS_TABLE=insight_category_counts
BQ_INSIGHT_SPORT_DISCIPLINE_TABLE=insight_sport_discipline
BQ_INSIGHT_SPORT_DISCIPLINE_MASTER_TABLE=insight_sport_discipline_master
BQ_FEED_QUALITY_TABLE=feed_quality

# Path to geojson + SAD CSVs. Defaults to the shared volume used by the legacy job.
INSIGHTS_GEO_DIR=../../volume-1/data-analysis
